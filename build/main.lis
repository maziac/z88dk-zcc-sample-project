  8839                             ; FILE  : _stdin
  8840                             ;
  8841                             ; driver: zx_01_input_kbd_inkey
  8842                             ; fd    : 0
  8843                             ; mode  : read only
  8844                             ; type  : 001 = input terminal
  8845                             ; tie   : __i_fcntl_fdstruct_1
  8846                             ;
  8847                             ; ioctl_flags   : CRT_ITERM_TERMINAL_FLAGS
  8848                             ; buffer size   : 64 bytes
  8849                             ; debounce      : CRT_ITERM_INKEY_DEBOUNCE ms
  8850                             ; repeat_start  : CRT_ITERM_INKEY_REPEAT_START ms
  8851                             ; repeat_period : CRT_ITERM_INKEY_REPEAT_RATE ms
  8852                             ;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;
