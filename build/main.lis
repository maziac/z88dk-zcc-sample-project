  5534                          defc __REG_TILEMAP_OFFSET_X_MSB = 0x2f
  5535                          
  5536                          ; Sets the X pixel offset (two low bits) used for drawing Tilemap graphics on the screen
  5537                          defc __REG_TILEMAP_OFFSET_X_LSB = 0x3
  5538                          
  5539                          ; Sets the Y pixel offset used for drawing Tilemap graphics on the screen
  5540                          defc __REG_TILEMAP_OFFSET_Y = 0x31
  5541                          
  5542                          ; Sets the transparency index for Tilemap graphics
  5543                          defc __REG_TILEMAP_TRANSPARENCY_INDEX = 0x4C
  5544                          
