  8824                          ; When FILEs and FDSTRUCTs are instantiated labels are assigned
  8825                          ; to point at created structures.
  8826                          ;
  8827                          ; The label formats are:
  8828                          ;
  8829                          ; __i_stdio_file_n     = address of static FILE structure #n (0..__I_STDIO_NUM_FILE-1)
  8830                          ; __i_fcntl_fdstruct_n = address of static FDSTRUCT #n (0..__I_FCNTL_NUM_FD-1)
  8831                          ; __i_fcntl_heap_n     = address of allocation #n on heap (0..__I_FCNTL_NUM_HEAP-1)
  8832                          
  8833                          
  8834                          
  8835                          
