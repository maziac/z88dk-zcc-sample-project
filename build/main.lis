  3135                             ; VERSION CHECKS (0 = no check)
  3136                             ;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;
  3137                          
  3138                             ;; core version = MMmmSSS (major, minor, sub) in decimal
  3139                             ;;    v 1.10.51 =  110051
  3140                          
  3141                             PUBLIC __CRT_CORE_VERSION
  3142                          
  3143                             IFNDEF CRT_CORE_VERSION
  3144                                defc CRT_CORE_VERSION = 0
  3145                             ENDIF
  3146                          
  3147                             defc __CRT_CORE_VERSION = CRT_CORE_VERSION
  3148                          
  3149                             ;; nextos version = MMmm (major, minor) in decimal
  3150                             ;;         v 1.94 =  194
  3151                          
  3152                             PUBLIC __NEXTOS_VERSION
  3153                          
  3154                             IFNDEF NEXTOS_VERSION
  3155                                defc NEXTOS_VERSION = -1
  3156                             ENDIF
  3157                          
  3158                             defc __NEXTOS_VERSION = NEXTOS_VERSION
  3159                          
  3160                             ;; esxdos version
  3161                             ;; currently non-zero checks for presence (use 1)
  3162                          
  3163                             PUBLIC __ESXDOS_VERSION
  3164                          
  3165                             IFNDEF ESXDOS_VERSION
  3166                                defc ESXDOS_VERSION = 0
  3167                             ENDIF
  3168                          
  3169                             defc __ESXDOS_VERSION = ESXDOS_VERSION
