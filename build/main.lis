  8968                                ; getk_repeatperiod_ms
  8969                          
  8970  0022  00                      defb 0
  8971  0023  00                      defb 0
  8972  0024  07                      defb CRT_ITERM_INKEY_DEBOUNCE
  8973  0025  ac0d                    defw CRT_ITERM_INKEY_REPEAT_START
  8974  0027  d200                    defw CRT_ITERM_INKEY_REPEAT_RATE
  8975                          
