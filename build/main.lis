  5565                          PUBLIC __REG_TILEMAP_OFFSET_X_LSB
  5566                          PUBLIC __REG_TILEMAP_OFFSET_Y
  5567                          PUBLIC __REG_TILEMAP_TRANSPARENCY_INDEX
  5568                          PUBLIC __RCWC_RESET_TILEMAP_CLIP_INDEX
  5569                          PUBLIC __RPC_SELECT_TILEMAP_PALETTE_0
  5570                          PUBLIC __RPC_SELECT_TILEMAP_PALETTE_1
