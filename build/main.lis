  5527                          ; Hardware tilemap (aka layer 3) registers
  5528                          ; ------------------------------------------
  5529                          
  5530                          ; Sets and reads the clip-window for Tilemap graphics
  5531                          defc __REG_CLIP_WINDOW_TILEMAP = 0x1B
  5532                          
