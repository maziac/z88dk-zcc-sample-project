  9407                          
  9408                                __stdio_block:
  9409                          
  9410  0000  00                         defb 0                ; no owner
  9411  0001  01                         defb 0x01             ; mtx_plain
  9412  0002  00                         defb 0                ; number of lock acquisitions
  9413  0003  fe                         defb 0xfe             ; spinlock (unlocked)
  9414  0004  0000                       defw 0                ; list of threads blocked on mutex
  9415                          
  9416                                IF __clib_stdio_heap_size > (146 + 14)
  9417                          
  9418                                   ; expand stdio heap to desired size
