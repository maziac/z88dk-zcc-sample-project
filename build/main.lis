  8922  0006  cd                      defb 205
  8923  0007  0000                    defw console_01_input_terminal_fdriver
  8924                          
  8925                                ; jump to driver
  8926                          
  8927  0009  c3                      defb 195
  8928  000a  0000                    defw zx_01_input_kbd_inkey
  8929                          
  8930                                ; flags
  8931                                ; reference_count
  8932                                ; mode_byte
  8933                          
  8934  000c  01                      defb 0x01      ; stdio handles ungetc + type = input terminal
  8935  000d  02                      defb 2
  8936  000e  01                      defb 0x01      ; read only
  8937                          
  8938                                ; ioctl_flags
  8939                          
  8940  000f  b003                    defw CRT_ITERM_TERMINAL_FLAGS
  8941                          
  8942                                ; mtx_plain
  8943                          
  8944  0011  00                      defb 0         ; thread owner = none
  8945  0012  01                      defb 0x01      ; mtx_plain
  8946  0013  00                      defb 0         ; lock count = 0
  8947  0014  fe                      defb 0xfe      ; atomic spinlock
  8948  0015  0000                    defw 0         ; list of blocked threads
