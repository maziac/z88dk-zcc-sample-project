  9421                          
  9422                                   __i_fcntl_heap_2:
  9423                          
  9424  0092  0000                          defw __i_fcntl_heap_3
  9425  0094  0000                          defw 0
  9426  0096  6900                          defw __i_fcntl_heap_1
  9427  0098  0000000000000000              defs __clib_stdio_heap_size - 146 - 14
              0000000000000000  
              0000000000000000  
              0000000000000000  
              0000000000000000  
              0000000000000000  
              0000000000000000  
              0000000000000000  
              0000000000000000  
              0000000000000000  
              0000000000000000  
              0000000000000000  
  9428                          
  9429                                   ; terminate stdio heap
  9430                          
  9431                                   SECTION data_fcntl_stdio_heap_tail
  9432                          
  9433  0000  0000                       __i_fcntl_heap_3:   defw 0
  9434                          
  9435                                ELSE
  9436                          
  9437                                   ; terminate stdio heap
  9438                          
  9439                                   SECTION data_fcntl_stdio_heap_tail
  9440                          
  9441                                   __i_fcntl_heap_2:   defw 0
  9442                          
  9443                                ENDIF
  9444                          
  9445                             ELSE
  9446                          
  9447                                ; no FDSTRUCTs statically created
  9448                          
  9449                                IF __clib_stdio_heap_size > 14
  9450                          
  9451                                   SECTION data_clib
  9452                                   SECTION data_fcntl
  9453                          
  9454                                   PUBLIC __stdio_heap
  9455                          
  9456                                   __stdio_heap:         defw __stdio_block
  9457                          
  9458                                   SECTION bss_clib
  9459                                   SECTION bss_fcntl
  9460                          
  9461                                   PUBLIC __stdio_block
  9462                          
  9463                                   __stdio_block:         defs __clib_stdio_heap_size
  9464                          
  9465                                   SECTION code_crt_init
  9466                          
  9467                                   ld hl,__stdio_block
  9468                                   ld bc,__clib_stdio_heap_size
  9469                          
  9470                                   EXTERN asm_heap_init
  9471                                   call asm_heap_init
  9472                          
  9473                                ENDIF
  9474                          
  9475                             ENDIF
