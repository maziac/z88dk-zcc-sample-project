  3172                             ; MAIN location for dotx and dotn commands
  3173                             ;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;
  3174                          
  3175                             IFNDEF CRT_ORG_MAIN
  3176                                defc CRT_ORG_MAIN = 0x8000
  3177                             ENDIF
  3178                          
  3179                             ; DOTX_RAMTOP can be set to alter ramtop check
  3180                          
  3181                             ;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;
  3182                             ; NextOS dotn
  3183                             ;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;
  3184                          
  3185                             ;; temporary stack location in divmmc
  3186                          
  3187                             IFNDEF DOTN_REGISTER_SP
  3188                                defc DOTN_REGISTER_SP = 0x4000
  3189                             ENDIF
  3190                          
  3191                             ;; last ram page in page table
  3192                          
  3193                             PUBLIC __DOTN_LAST_PAGE
  3194                          
  3195                             IFNDEF DOTN_LAST_PAGE
  3196                                defc DOTN_LAST_PAGE = __ZXNEXT_LAST_PAGE
  3197                             ENDIF
  3198                          
  3199                             IF DOTN_LAST_PAGE < 11
  3200                                error "DOTN_LAST_PAGE must be at least 11"
  3201                             ELSE
  3202                                IF DOTN_LAST_PAGE > __ZXNEXT_LAST_PAGE
  3203                                   error "DOTN_LAST_PAGE cannot exceed 223"
  3204                                ELSE
  3205                                   defc __DOTN_LAST_PAGE = DOTN_LAST_PAGE
  3206                                ENDIF
  3207                             ENDIF
  3208                          
  3209                             ;; last divmmc page in divmmc table
  3210                          
  3211                             PUBLIC __DOTN_LAST_DIVMMC
  3212                          
  3213                             IFNDEF DOTN_LAST_DIVMMC
  3214                                defc DOTN_LAST_DIVMMC = -1
  3215                             ENDIF
  3216                          
  3217                             IF DOTN_LAST_DIVMMC > __ZXNEXT_LAST_DIVMMC
  3218                                error "DOTN_LAST_DIVMMC cannot exceed 15"
  3219                             ELSE
  3220                                defc __DOTN_LAST_DIVMMC = DOTN_LAST_DIVMMC
  3221                             ENDIF
  3222                          
  3223                             ;; number of extra ram pages to allocate
  3224                          
