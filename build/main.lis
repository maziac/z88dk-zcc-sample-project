  3502                             ; banked calls configuration
  3503                             ; MMU Next register to be used for banked calls depends on the value of CLIB_BANKING_SEGMENT:
  3504                             ;   0: MMU 0 and 1
  3505                             ;   1: MMU 2 and 3
  3506                             ;   2: MMU 4 and 5
  3507                             ;   3: MMU 6 and 7
  3508                          
  3509                             PUBLIC CLIB_BANKING_SEGMENT
  3510                          
  3511                             IFNDEF CLIB_BANKING_SEGMENT
  3512                                defc CLIB_BANKING_SEGMENT = 3
  3513                             ENDIF
  3514                          
  3515                             PUBLIC CLIB_BANKING_STACK_SIZE
  3516                          
  3517                             IFNDEF CLIB_BANKING_STACK_SIZE
  3518                                defc CLIB_BANKING_STACK_SIZE = 100
  3519                             ENDIF
