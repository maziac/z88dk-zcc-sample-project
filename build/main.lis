  9388                             ;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;
  9389                          
  9390                             ; __clib_stdio_heap_size  = desired stdio heap size in bytes
