  9282                                      call asm_p_forward_list_alt_push_front
  9283                          
  9284                                      ld de,15
  9285                                      add hl,de
  9286                                      ex de,hl
  9287                          
  9288                                      pop hl
  9289                          
  9290                                      dec l
