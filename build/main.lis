  9254                                SECTION data_stdio
  9255                          
  9256                                PUBLIC __stdio_closed_file_list
  9257                          
  9258  0035  00003500                __stdio_closed_file_list:   defw 0, __stdio_closed_file_list
  9259                          
  9260                                IF __clib_fopen_max > 3
  9261                          
  9262                                   defc __MAX_FOPEN = __clib_fopen_max
  9263                          
  9264                                   ; create extra FILE structures
  9265                          
  9266                                   SECTION bss_clib
  9267                                   SECTION bss_stdio
  9268                          
  9269                                   __stdio_file_extra:      defs (__clib_fopen_max - 3) * 15
  9270                          
  9271                                   SECTION code_crt_init
  9272                          
  9273                                      ld bc,__stdio_closed_file_list
  9274                                      ld de,__stdio_file_extra
  9275                                      ld l,__clib_fopen_max - 3
  9276                          
  9277                                   loop:
  9278                          
  9279                                      push hl
  9280                          
