  9209                             ;; create open and closed FILE lists
  9210                             ;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;
  9211                          
  9212                             ; __clib_fopen_max   = max number of open FILEs specified by user
  9213                             ; 3 = number of static FILEs instantiated in crt
  9214                             ; __i_stdio_file_n   = address of static FILE structure #n (0..I_STDIO_FILE_NUM-1)
  9215                          
  9216                          	PUBLIC __MAX_FOPEN
  9217                          
  9218                             SECTION data_clib
  9219                             SECTION data_stdio
  9220                          
  9221                             IF (__clib_fopen_max > 0) || (3 > 0)
  9222                          
  9223                                ; number of FILEs > 0
  9224                          
  9225                                ; construct list of open files
  9226                          
  9227                                IF 3 > 0
  9228                          
  9229                                   ; number of FILEs statically generated > 0
  9230                          
  9231                                   SECTION data_clib
  9232                                   SECTION data_stdio
  9233                          
  9234                                   PUBLIC __stdio_open_file_list
  9235                          
  9236  0033  2400                       __stdio_open_file_list:  defw __i_stdio_file_2
  9237                          
  9238                                ELSE
  9239                          
  9240                                   ; number of FILEs statically generated = 0
  9241                          
  9242                                   SECTION bss_clib
  9243                                   SECTION bss_stdio
  9244                          
  9245                                   PUBLIC __stdio_open_file_list
  9246                          
  9247                                   __stdio_open_file_list:  defw 0
  9248                          
  9249                                ENDIF
  9250                          
  9251                                ; construct list of closed / available FILEs
  9252                          
