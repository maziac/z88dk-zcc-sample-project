  8863                          
  8864                             ; FILE structure
  8865                          
  8866                             __i_stdio_file_0:
  8867                          
  8868                                ; open files link
  8869                          
  8870  0002  0000                    defw 0
  8871                          
  8872                                ; jump to underlying fd
  8873                          
  8874  0004  c3                      defb 195
  8875  0005  0600                    defw __i_fcntl_fdstruct_0
  8876                          
  8877                                ; state_flags_0
  8878                                ; state_flags_1
  8879                                ; conversion flags
  8880                                ; ungetc
  8881                          
  8882  0007  40                      defb 0x40      ; read + stdio manages ungetc + normal file type
  8883  0008  02                      defb 0x02      ; last operation was read
  8884  0009  00                      defb 0
  8885  000a  00                      defb 0
  8886                          
  8887                                ; mtx_recursive
  8888                          
  8889  000b  00                      defb 0         ; thread owner = none
  8890  000c  02                      defb 0x02      ; mtx_recursive
  8891  000d  00                      defb 0         ; lock count = 0
  8892  000e  fe                      defb 0xfe      ; atomic spinlock
  8893  000f  0000                    defw 0         ; list of blocked threads
  8894                          
  8895                          
  8896                             ; fd table entry
  8897                          
  8898                             SECTION data_fcntl_fdtable_body
  8899  0000  0600                 defw __i_fcntl_fdstruct_0
  8900                          
