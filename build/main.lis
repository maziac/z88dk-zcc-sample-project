  5573                          
  5574                          ; ------------------------------------------
  5575                          ; Hardware sprites registers and flags
  5576                          ; ------------------------------------------
  5577                          
  5578                          ; Register for selection of the active sprite attribute and pattern slot index
  5579                          defc __REG_SPRITE_NUMBER = 0x34
  5580                          
  5581                          ; Low 8 bits of sprite X position registers
  5582                          defc __REG_SPRITE_ATTR_X = 0x35
  5583                          defc __REG_SPRITE_ATTR_0 = 0x35
  5584                          defc __REG_SPRITE_ATTR_X_INCREMENT = 0x75
  5585                          defc __REG_SPRITE_ATTR_0_INCREMENT = 0x75
  5586                          
  5587                          ; Low 8 bits of sprite Y position registers
  5588                          defc __REG_SPRITE_ATTR_Y = 0x36
  5589                          defc __REG_SPRITE_ATTR_1 = 0x36
  5590                          defc __REG_SPRITE_ATTR_Y_INCREMENT = 0x76
  5591                          defc __REG_SPRITE_ATTR_1_INCREMENT = 0x76
  5592                          
  5593                          ; Sprite attr 2 registers
  5594                          defc __REG_SPRITE_ATTR2 = 0x37
  5595                          defc __REG_SPRITE_ATTR2_INCREMENT = 0x77
  5596                          
  5597                          ; Sprite attr 2 flags
  5598                          defc __RSA2_ENABLE_X_MIRRORING = 0x08
  5599                          defc __RSA2_ENABLE_Y_MIRRORING = 0x04
  5600                          defc __RSA2_ROTATE_CLOCKWISE = 0x02
  5601                          defc __RSA2_RELATIVE_ANCHOR_PALETTE = 0x01
  5602                          
  5603                          ; Sprite attr 3 registers
  5604                          defc __REG_SPRITE_ATTR3 = 0x38
  5605                          defc __REG_SPRITE_ATTR3_INCREMENT = 0x78
  5606                          
  5607                          ; Sprite attr 3 flags
  5608                          defc __RSA3_VISIBLE = 0x80
  5609                          defc __RSA3_USE_BYTE_4 = 0x40
  5610                          
  5611                          ; Sprite attr 4 register
  5612                          defc __REG_SPRITE_ATTR4 = 0x39
  5613                          defc __REG_SPRITE_ATTR4_INCREMENT = 0x79
  5614                          
  5615                          ; Sprite attr 4 flags for anchor sprites
  5616                          defc __RSA4_ANCHOR_SPRITE_8BIT = 0b00000000
  5617                          defc __RSA4_ANCHOR_SPRITE_4BIT_0_127_PATTERN = 0b10000000
  5618                          defc __RSA4_ANCHOR_SPRITE_4BIT_128_255_PATTERN = 0b11000000
  5619                          defc __RSA4_ANCHOR_UNIFIED = 0b00100000
  5620                          defc __RSA4_ANCHOR_COMPOSITE = 0b00000000
  5621                          
  5622                          ; Sprite attr 4 flags for composite relative sprites
  5623                          defc __RSA4_RELATIVE_SPRITE = 0b01000000
  5624                          defc __RSA4_RELATIVE_ANCHOR_PATTERN = 0b00000001
  5625                          
  5626                          ; Sprite attr 4 flags for scaling
  5627                          defc __RSA4_X_SCALE_2X = 0b00001000
  5628                          defc __RSA4_X_SCALE_4X = 0b00010000
  5629                          defc __RSA4_X_SCALE_8X = 0b00011000
  5630                          defc __RSA4_Y_SCALE_2X = 0b00000100
  5631                          defc __RSA4_Y_SCALE_4X = 0b00000010
  5632                          defc __RSA4_Y_SCALE_8X = 0b00000110
  5633                          
  5634                          ; ----------------------------------------------------------------------------
  5635                          ; Sprite flags for Sprite and Layers System register (REG_SPRITE_LAYER_SYSTEM)
  5636                          ; ----------------------------------------------------------------------------
  5637                          
  5638                          ; Enable cliping of sprites over the border
  5639                          defc __RSLS_ENABLE_SPRITES_CLIPING_OVER_BORDER = 0x20
  5640                          
  5641                          
  5642                          PUBLIC __REG_SPRITE_NUMBER
  5643                          PUBLIC __REG_SPRITE_ATTR_X
  5644                          PUBLIC __REG_SPRITE_ATTR_0
  5645                          PUBLIC __REG_SPRITE_ATTR_X_INCREMENT
  5646                          PUBLIC __REG_SPRITE_ATTR_0_INCREMENT
  5647                          PUBLIC __REG_SPRITE_ATTR_Y
  5648                          PUBLIC __REG_SPRITE_ATTR_1
  5649                          PUBLIC __REG_SPRITE_ATTR_Y_INCREMENT
  5650                          PUBLIC __REG_SPRITE_ATTR_1_INCREMENT
  5651                          PUBLIC __REG_SPRITE_ATTR2
  5652                          PUBLIC __REG_SPRITE_ATTR2_INCREMENT
  5653                          PUBLIC __RSA2_ENABLE_X_MIRRORING
  5654                          PUBLIC __RSA2_ENABLE_Y_MIRRORING
