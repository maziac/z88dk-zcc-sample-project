   765                             IF __Z180
   766                          
   767                                PUBLIC __IO_VECTOR_BASE
   768                          
   769                                IF __crt_io_vector_base < 0
   770                          
   771                                   IF (__crt_org_vector_table < 0)
   772                          
   773                                      IF (-__crt_org_vector_table) & 0x1f
   774                          
   775                                         "Cannot place __IO_VECTOR_BASE at start of interrupt vector table"
   776                          
   777                                      ELSE
   778                          
   779                                         defc __IO_VECTOR_BASE = (-__crt_org_vector_table) & 0xe0
   780                          
   781                                      ENDIF
   782                          
   783                                   ELSE
   784                          
   785                                      IF __crt_org_vector_table & 0x1f
   786                          
   787                                         "Cannot place __IO_VECTOR_BASE at start of interrupt vector table"
   788                          
   789                                      ELSE
   790                          
   791                                         defc __IO_VECTOR_BASE = __crt_org_vector_table & 0xe0
   792                          
   793                                      ENDIF
   794                          
   795                                   ENDIF
   796                          
   797                                ELSE
   798                          
   799                                   IF __crt_io_vector_base & 0x1f
   800                          
   801                                      "Illegal __IO_VECTOR_BASE"
   802                          
   803                                   ELSE
   804                          
   805                                      defc __IO_VECTOR_BASE = __crt_io_vector_base & 0xe0
   806                          
   807                                   ENDIF
   808                          
   809                                ENDIF
   810                          
   811                             ENDIF
