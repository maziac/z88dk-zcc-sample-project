  3229                             ENDIF
  3230                          
  3231                             defc __DOTN_NUM_EXTRA = DOTN_NUM_EXTRA
  3232                          
  3233                             ;; set bits indicate mmus that should be allocated in the main bank
  3234                          
  3235                             PUBLIC __DOTN_MAIN_OVERLAY_MASK
  3236                          
  3237                             IFNDEF DOTN_MAIN_OVERLAY_MASK
  3238                                defc DOTN_MAIN_OVERLAY_MASK = 0
  3239                             ENDIF
  3240                          
  3241                             defc __DOTN_MAIN_OVERLAY_MASK = DOTN_MAIN_OVERLAY_MASK & 0xff
  3242                          
  3243                             ;; set bits indicates mmus that should not be allocated in the main bank
  3244                          
  3245                             PUBLIC __DOTN_MAIN_ABSOLUTE_MASK
  3246                          
  3247                             IFNDEF DOTN_MAIN_ABSOLUTE_MASK
  3248                                defc DOTN_MAIN_ABSOLUTE_MASK = 0
  3249                             ENDIF
  3250                          
  3251                             defc __DOTN_MAIN_ABSOLUTE_MASK = DOTN_MAIN_ABSOLUTE_MASK & 0xff
