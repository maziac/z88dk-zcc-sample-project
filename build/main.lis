  5665                          PUBLIC __RSA4_ANCHOR_SPRITE_4BIT_128_255_PATTERN
  5666                          PUBLIC __RSA4_ANCHOR_UNIFIED
  5667                          PUBLIC __RSA4_ANCHOR_COMPOSITE
  5668                          PUBLIC __RSA4_RELATIVE_SPRITE
